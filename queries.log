  from 
    test.users as ref_0
  where (select max(score) from test.users)
       >= 41.33), cte_3 as (select  
    ref_0.product as c0
  from 
    test.orders as ref_0
  where (select score from test.users limit 1 offset 40)
       >= ref_0.amount), cte_4 as (select  
    ref_0.price as c0, 
    ref_0.price as c1
  from 
    test.products as ref_0
  where 1), cte_5 as (select  
    ref_0.score as c0
  from 
    test.users as ref_0
  where (ref_0.score = (select amount from test.orders limit 1 offset 3)
        ) 
    or ((select stock from test.products limit 1 offset 34)
         is not NULL))
select  
    ref_0.category as c0
  from 
    test.products as ref_0
  where EXISTS (
    select  
        ref_0.description as c0
      from 
        cte_0 as ref_1
      where EXISTS (
        select  
            (select email from test.users limit 1 offset 3)
               as c0
          from 
            test.products as ref_2
          where ref_0.stock < (select avg(id) from test.users)
              
          limit 14));
select  
  last_insert_id() as c0, 
  subq_0.c3 as c1
from 
  test.users as ref_0
    inner join (select  
          ref_1.score as c0, 
          (select count(id) from test.users)
             as c1, 
          ref_1.id as c2, 
          ref_1.id as c3, 
          (select score from test.users limit 1 offset 3)
             as c4
        from 
          test.users as ref_1
        where ref_1.score is not NULL
        limit 41) as subq_0
    on (ref_0.id = subq_0.c1 )
where EXISTS (
  select  
      (select user_id from test.orders limit 1 offset 1)
         as c0, 
      subq_0.c2 as c1
    from 
      test.orders as ref_1
    where (1) 
      or (1))
 for update;
with cte_0 as (select  
    ref_0.age as c0, 
    case when ref_0.id is not NULL then ref_0.id else ref_0.id end
       as c1
  from 
    test.users as ref_0
  where EXISTS (
    select  
        ref_1.user_id as c0
      from 
        test.orders as ref_1
      where 1))
select  
    ref_0.order_date as c0, 
    case when ref_0.order_date > ref_0.order_date then -2 else -2 end
       as c1
  from 
    test.orders as ref_0
  where ref_0.amount is not NULL
  limit 23;
